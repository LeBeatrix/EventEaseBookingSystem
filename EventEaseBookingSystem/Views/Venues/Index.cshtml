@model IEnumerable<EventEaseBookingSystem.Models.Venue>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">Add New Venue</a>
</p>

<div class="row">

    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card venue-card h-100">

                <img src="@item.ImageUrl" class="card-img-top venue-img" />

                <div class="card-body">
                    <h5 class="card-title">@item.VenueName</h5>

                    <p class="card-text">
                        <strong>Location:</strong> @item.Location <br />
                        <strong>Capacity:</strong> @item.Capacity
                    </p>
                </div>

                <div class="card-footer bg-white border-0 text-center">
                    <a asp-action="Details" asp-route-id="@item.VenueId" class="btn btn-primary btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.VenueId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.VenueId" class="btn btn-danger btn-sm">Delete</a>
                </div>

            </div>
        </div>
    }

</div>

<style>

    .venue-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        border-radius: 10px;
    }

        .venue-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
        }

    .venue-img {
        height: 220px;
        object-fit: cover;
        border-top-left-radius: 10px;
        border-top-right-radius: 10px;
    }

</style>
